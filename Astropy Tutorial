print(image_data.shape)

#Display the image data (single plot):
plt.figure()
plt.imshow(image_data, cmap='gray')
plt.colorbar()
plt.grid(False)

#Display two plots side by side, one logarithmic and one linear:
fig, (ax1, ax2) = plt.subplots(1, 2)
