import numpy as np
import matplotlib.pyplot as plt
import os
from astropy.visualization import astropy_mpl_style
plt.style.use(astropy_mpl_style)
from astropy.io import fits
from astropy.utils.data import get_pkg_data_filename
from matplotlib.colors import LogNorm

image_file = os.path.join('/Users/applestore/Downloads', 'kp1513517.fits.fz' )

# display the structure of the file
fits.info(image_file)

#read the image data (my file didn't have ext=0 (sort of means it had no header))
image_data = fits.getdata(image_file, ext=1)

#The data is now stored as a 2D numpy array. Print the dimensions using the shape attribute:

print(type(image_data))
print(image_data.shape)

#Display the image data (single plot):
plt.figure()
plt.imshow(image_data, cmap='gray')
plt.colorbar()
plt.grid(False)

#Display two plots side by side, one logarithmic and one linear:
fig, (ax1, ax2) = plt.subplots(1, 2)
ax1.imshow(image_data, cmap='gray', norm=LogNorm())
ax1.set_title('Logarithmic Scale')
ax1.grid(False)

ax2.imshow(image_data, cmap='gray', norm=None)
ax2.set_title('Normal Linear Scale')
ax2.grid(False)

plt.tight_layout()
plt.show()

# Next we look more into the data in the file
print('Min:', np.min(image_data))
print('Max:', np.max(image_data))
print('Mean:', np.mean(image_data))
print('Stdev:', np.std(image_data))

print(type(image_data.flatten()))
print(image_data.flatten().shape)

# And this is for plotting a histogram if needed:
histogram = plt.hist(image_data.flatten(), bins='auto')

